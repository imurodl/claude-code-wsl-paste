#!/bin/bash
# wl-paste wrapper for WSL + Claude Code
# Uses win32yank.exe for text and PowerShell for images,
# bypassing WSLg clipboard bridge to avoid ghost empty entries in Windows clipboard history.
#
# Project: https://github.com/imurodl/claude-code-wsl-paste

WIN32YANK="win32yank.exe"
TEMP_IMG="/tmp/.clipboard-image.png"

# Auto-detect WSL distro name for UNC path
WSL_DISTRO="${WSL_DISTRO_NAME:-Ubuntu}"

# If listing types — always report both text and image as available.
# PowerShell is NOT called here to avoid clipboard side effects.
# The actual image read handles the "no image" case gracefully.
if [[ "$*" == *"--list-types"* ]] || [[ "$*" == *"-l"* ]]; then
    echo "text/plain"
    echo "image/png"
    exit 0
fi

# If requesting image/png, grab from Windows clipboard via PowerShell
if [[ "$*" == *"image/png"* ]]; then
    # Remove stale temp file
    rm -f "$TEMP_IMG"

    powershell.exe -NoProfile -STA -Command "
Add-Type -AssemblyName System.Windows.Forms
try {
    \$img = [System.Windows.Forms.Clipboard]::GetImage()
    if (\$img -ne \$null) {
        \$path = '\\\\wsl.localhost\\${WSL_DISTRO}${TEMP_IMG}'
        \$img.Save(\$path, [System.Drawing.Imaging.ImageFormat]::Png)
        \$img.Dispose()
    }
} catch {}
" 2>/dev/null

    if [[ -f "$TEMP_IMG" ]]; then
        cat "$TEMP_IMG"
        exit 0
    fi
    exit 1
fi

# Default: text paste via win32yank
exec $WIN32YANK -o --lf
