#!/bin/bash
# wl-paste wrapper for WSL + Claude Code
# Uses win32yank.exe for text and PowerShell for images,
# bypassing WSLg clipboard bridge to avoid ghost empty entries in Windows clipboard history.
#
# Project: https://github.com/imurodl/claude-code-wsl-paste

WIN32YANK="win32yank.exe"
TEMP_IMG="/tmp/.clipboard-image.png"

# Auto-detect WSL distro name for UNC path
WSL_DISTRO="${WSL_DISTRO_NAME:-Ubuntu}"

# If listing types, check what's on the Windows clipboard
if [[ "$*" == *"--list-types"* ]] || [[ "$*" == *"-l"* ]]; then
    # Save image to temp file AND report types in one PowerShell call
    img_result=$(powershell.exe -NoProfile -STA -Command "
Add-Type -AssemblyName System.Windows.Forms
try {
    \$img = [System.Windows.Forms.Clipboard]::GetImage()
    if (\$img -ne \$null) {
        \$path = '\\\\wsl.localhost\\${WSL_DISTRO}${TEMP_IMG}'
        \$img.Save(\$path, [System.Drawing.Imaging.ImageFormat]::Png)
        \$img.Dispose()
        Write-Output 'HAS_IMAGE'
    }
} catch {}
" 2>/dev/null | tr -d '\r\n')

    has_text=$($WIN32YANK -o 2>/dev/null | head -c1)

    types=""
    if [[ -n "$has_text" ]]; then
        types="text/plain"
    fi
    if [[ "$img_result" == "HAS_IMAGE" ]] && [[ -f "$TEMP_IMG" ]]; then
        types="${types:+$types$'\n'}image/png"
    fi
    echo "$types"
    exit 0
fi

# If requesting image/png, return the pre-saved temp file
if [[ "$*" == *"image/png"* ]]; then
    if [[ -f "$TEMP_IMG" ]]; then
        cat "$TEMP_IMG"
        exit 0
    fi
    # Fallback: try saving now
    powershell.exe -NoProfile -STA -Command "
Add-Type -AssemblyName System.Windows.Forms
try {
    \$img = [System.Windows.Forms.Clipboard]::GetImage()
    if (\$img -ne \$null) {
        \$path = '\\\\wsl.localhost\\${WSL_DISTRO}${TEMP_IMG}'
        \$img.Save(\$path, [System.Drawing.Imaging.ImageFormat]::Png)
        \$img.Dispose()
    }
} catch {}
" 2>/dev/null
    if [[ -f "$TEMP_IMG" ]]; then
        cat "$TEMP_IMG"
        exit 0
    fi
    exit 1
fi

# Default: text paste via win32yank
exec $WIN32YANK -o --lf
