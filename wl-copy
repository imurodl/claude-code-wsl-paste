#!/bin/bash
# wl-copy wrapper for WSL
# Uses win32yank.exe to write to Windows clipboard,
# bypassing WSLg bridge to avoid ghost empty entries in clipboard history.
#
# Project: https://github.com/imurodl/claude-code-wsl-paste

WIN32YANK="win32yank.exe"

# Pass stdin to win32yank
exec $WIN32YANK -i --crlf
